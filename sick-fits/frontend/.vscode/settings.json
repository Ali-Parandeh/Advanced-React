{
  "workbench.colorCustomizations": {
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveForeground": "#15202b99",
    "titleBar.activeBackground": "#ffc600",
    "titleBar.inactiveBackground": "#ffc600",
    "activityBar.activeBackground": "#009f7b",
    "activityBar.activeBorder": "#15202b",
    "activityBar.background": "#ffd133",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#009f7b",
    "activityBarBadge.foreground": "#e7e7e7",
    "statusBar.background": "#ffc600",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#cc9e00"
  },
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.formatOnSave": false
  },
  "[javascriptreact]": {
    "editor.formatOnSave": false
  },
  "eslint.alwaysShowStatus": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": true
  },
  "prettier.disableLanguages": ["javascript", "javascriptreact"],
  "peacock.color": "#FFC600"
}
